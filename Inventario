def menu():
    inventario = []

    while True:
        print("\n--- INVENTARIO ---")
        print("1. Agregar producto")
        print("2. Buscar producto")
        print("3. Actualizar cantidad")
        print("4. Valor total")
        print("5. Stock bajo")
        print("6. Exportar JSON")
        print("7. Salir")

        opcion = input("Elige una opción: ")

        if opcion == "1":
            agregar_producto(inventario)
        elif opcion == "2":
            buscar_producto(inventario)
        elif opcion == "3":
            actualizar_cantidad(inventario)
        elif opcion == "4":
            valor_total(inventario)
        elif opcion == "5":
            stock_bajo(inventario)
        elif opcion == "6":
            exportar_json(inventario)
        elif opcion == "7":
            print("👋 Saliendo...")
            break
        else:
            print("❌ Opción inválida")


# Ejecutar
menu()
