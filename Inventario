def agregar_producto(inventario):
    nombre = input("Nombre del producto: ").strip()
    
    if not nombre:
        print("❌ Nombre inválido")
        return
    
    precio = float(input("Precio: "))
    cantidad = int(input("Cantidad: "))
    categoria = input("Categoría: ")

    producto = {
        "nombre": nombre,
        "precio": precio,
        "cantidad": cantidad,
        "categoria": categoria
    }

    inventario.append(producto)
    print("✅ Producto agregado")


def buscar_producto(inventario):
    termino = input("Buscar por nombre o categoría: ").lower()

    resultados = [
        p for p in inventario
        if termino in p.get("nombre").lower() or termino in p.get("categoria").lower()
    ]

    if resultados:
        for p in resultados:
            print(p)
    else:
        print("❌ No se encontraron resultados")


def actualizar_cantidad(inventario):
    nombre = input("Producto: ").lower()

    for p in inventario:
        if p.get("nombre").lower() == nombre:
            tipo = input("¿Venta o restock? (v/r): ").lower()
            cantidad = int(input("Cantidad: "))

            if tipo == "v":
                p["cantidad"] -= cantidad
            elif tipo == "r":
                p["cantidad"] += cantidad

            print("✅ Cantidad actualizada")
            return

    print("❌ Producto no encontrado")


def valor_total(inventario):
    total = sum(p["precio"] * p["cantidad"] for p in inventario)
    print(f"💰 Valor total: {total}")


def stock_bajo(inventario):
    bajos = [p for p in inventario if p["cantidad"] < 5]

    if bajos:
        print("⚠️ Productos con stock bajo:")
        for p in bajos:
            print(p)
    else:
        print("✅ No hay productos con stock bajo")


